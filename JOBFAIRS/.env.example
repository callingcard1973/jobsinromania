# European Employer ANOFM Job Fair Integration System
# Environment Configuration Template
#
# Copy this file to .env and fill in your actual values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Local SQLite Database
SQLITE_PATH=data/jobfairs.db

# Master PostgreSQL Database (raspibig)
POSTGRES_HOST=192.168.100.21
POSTGRES_PORT=5432
POSTGRES_DATABASE=interjob_master
POSTGRES_USER=tudor
POSTGRES_PASSWORD=tudor

# =============================================================================
# EMAIL CONFIGURATION (BREVO API)
# =============================================================================

# Brevo API Configuration - REQUIRED
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@interjob.ro
BREVO_SENDER_NAME=InterJob Romania

# Email Limits
DAILY_EMAIL_LIMIT=500
PILOT_DAILY_LIMIT=50
SCALING_DAILY_LIMIT=200

# =============================================================================
# GDPR COMPLIANCE SETTINGS
# =============================================================================

# Data Retention Periods (in days)
WORKER_DATA_RETENTION_DAYS=1095      # 3 years for workers
EMPLOYER_DATA_RETENTION_DAYS=2555    # 7 years for employers
COMMUNICATION_RETENTION_DAYS=1095    # 3 years for communications

# Data Controller Information
DATA_CONTROLLER=InterJob Romania
DATA_CONTROLLER_ADDRESS=Bucharest, Romania
DATA_PROCESSOR=InterJob Romania
PRIVACY_POLICY_URL=https://interjob.ro/privacy.html

# =============================================================================
# ANOFM WEBSITE MONITORING
# =============================================================================

ANOFM_BASE_URL=https://www.anofm.ro
ANOFM_JOB_FAIRS_PATH=/burse-de-munca
ANOFM_CHECK_INTERVAL_HOURS=6

# Target regions for job fair monitoring (comma-separated)
TARGET_REGIONS=Hunedoara,Gorj,Vaslui

# =============================================================================
# SYSTEM OPERATIONAL LIMITS
# =============================================================================

# Pilot Phase (30 days)
PILOT_MAX_EMPLOYERS=1
PILOT_MAX_WORKERS=10
PILOT_DURATION_DAYS=30

# Scaling Phase (60 days)
SCALING_MAX_EMPLOYERS=5
SCALING_MAX_WORKERS=50
SCALING_DURATION_DAYS=60

# Full Deployment
FULL_MAX_EMPLOYERS=50
FULL_MAX_WORKERS=500

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/jobfairs.log
LOG_MAX_BYTES=10485760    # 10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# INTEGRATION WITH EXISTING INFRASTRUCTURE
# =============================================================================

# OpenCage Geocoding API (for address validation)
OPENCAGE_API_KEY=your_opencage_key_here

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here

# =============================================================================
# NOTES FOR DEPLOYMENT
# =============================================================================
#
# PRODUCTION CHECKLIST:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Configure real Brevo API key
# 4. Set up PostgreSQL connection to raspibig
# 5. Configure proper logging paths
# 6. Set GDPR retention periods per legal requirements
# 7. Configure target regions based on current layoff areas
# 8. Set operational limits based on deployment phase
#
# SECURITY:
# - Keep this file out of version control
# - Use strong passwords for database connections
# - Limit API key permissions to minimum required
# - Regularly rotate API keys
# - Monitor access logs
#
# INTEGRATION:
# - Database connects to existing master DB on raspibig
# - Email system uses existing Brevo infrastructure
# - Respects existing daily email limits (500/day)
# - Follows GDPR compliance patterns from existing system
#