# Database
DATABASE_URL=sqlite:///./classified_ads.db

# Security — REQUIRED: Must be set to a strong random value (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use the default placeholder in production
SECRET_KEY=your-secret-key-change-in-production

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App Settings
ENVIRONMENT=development
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# PostHog Analytics
# Get your API key from https://posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com
POSTHOG_ENABLED=true

# Payments (Stripe) — pay-to-publish
# Leave STRIPE_SECRET_KEY empty to run in sandbox mode (no real charges)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Flat fee charged to publish an ad, in the smallest currency unit (e.g. cents)
AD_PUBLISH_PRICE_CENTS=500
CURRENCY=usd

# WordPress integration — push published ads as WP posts
# Leave WP_SITE_URL empty to disable
WP_SITE_URL=https://ads.cifn.eu
WP_USER=admin
WP_APP_PASSWORD=
WP_ENABLED=false
# WP category ID for "Classifieds" (create in WP dashboard, note the ID)
WP_DEFAULT_CATEGORY_ID=0